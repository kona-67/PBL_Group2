/*login.html*/
/*フッダー*/
.login h2{
    text-align: center;
}

/*emailエリア*/
.login .email-area{
    width: 60%;
    max-width: 500px;
    margin: 0 auto;
}

.login .email-area label{
    display: block;
    text-align: left;
}

.login #email{
    width: 100%;
    height: 40px;
    font-size: 18px;
    box-sizing: border-box;
}

/*passwordエリア*/
.login .password-area{
    width: 60%;
    max-width: 500px;
    margin: 0 auto;
}

.login .password-area label{
    display: block;
    text-align: left;
}

/*passwordエリア,確認用エリアの欄*/
.login #password{
    width: 100%;
    height: 40px;
    font-size: 18px;
    box-sizing: border-box;
}

/*ボタン*/
.login .sendBtn-area{
    display: flex;
    justify-content: center;
    
}

.login .sendBtn{
    height: 50px;
    width: 15vw;
}




